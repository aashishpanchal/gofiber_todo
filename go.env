PORT=8000
HOST="127.0.0.1"
GO_ENV="development" # development, production
SECRET="server_secret_key"
CORS_ALLOW_ORIGIN="http://localhost:5173"
# Body parser
BODY_LIMIT="2MB"
# JWT Config
JWT_ACCESS_EXP="15m"
JWT_REFRESH_EXP="1h"
# Rate limiter
RATE_LIMIT_WINDOWS="15m"
RATE_LIMIT_MAX_REQ=100
# Database Config
DB_URL="postgresql://[user]:[password]@127.0.0.1:5432/[database]"
# Production (NGINX/Cloudflare/LB)
TRUST_PROXY=false
PROXY_HEADER="x-proxy-header"

# Note:
# Go duration format: <num>ms,s,m,h
# Example: 500ms, 30s, 5m, 1h, 2h45m and 1h30m10s ...etc
